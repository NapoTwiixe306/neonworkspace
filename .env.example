# Configuration SMTP du formulaire de contact (nodemailer).
# Copie ce fichier en .env.local et renseigne tes vraies valeurs.
# Exemple avec Gmail : crée un "mot de passe d'application" (pas ton mot de passe
# habituel) sur https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.adresse@gmail.com
SMTP_PASS=ton_mot_de_passe_application

# Adresse qui reçoit les messages (optionnel, par défaut SMTP_USER / l'email du site).
CONTACT_TO=julien.milants@gmail.com

# Analytics Umami (self-hosted). Le script n'est injecté que si les DEUX
# variables sont définies : rien à faire en dev, à renseigner sur le VPS.
# NEXT_PUBLIC_UMAMI_SRC=https://umami.mondomaine.be/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
